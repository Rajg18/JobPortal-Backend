# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local MySQL:
DB_URL=jdbc:mysql://localhost:3306/portalDB
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# Render / Railway PostgreSQL (replace with the URL from your dashboard):
# DB_URL=jdbc:postgresql://<host>:<port>/<dbname>
# DB_USERNAME=your_pg_user
# DB_PASSWORD=your_pg_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong Base64-encoded secret (min 256-bit / 32 bytes):
#   openssl rand -base64 32
JWT_SECRET=replace_with_a_strong_base64_encoded_secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000
